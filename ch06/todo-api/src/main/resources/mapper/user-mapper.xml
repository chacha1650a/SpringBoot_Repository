<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.korit.todoapi.mapper.UserMapper">
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into users values
        (default, #{email}, #{nickname}, #{profileImage}, #{provider}, #{providerId}, now());
    </insert>

    <select id="selectByProviderId" resultType="com.korit.todoapi.entity.User">
        select
            id,
            email,
            nickname,
            profile_image,
            provider,
            provider_id,
            created_at
        from
            users
        where
            provider_id = #{providerId};
    </select>

    <select id="selectById" resultType="com.korit.todoapi.entity.User">


    </select>
</mapper>