<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.korit.ch04api.mapper.RoleMapper">

    <insert id="insert" parameterType="Role" useGeneratedKeys="true" keyProperty="id">
        insert into roles values
            (default, #{roleName})
    </insert>

    <insert id="insertMany" parameterType="Role" useGeneratedKeys="true" keyProperty="id">
        insert into roles values
        <foreach item="role" collection="roles" separator=",">
            (default, #{role.roleName})
        </foreach>
    </insert>

    <select id="selectAll" resultType="Role">
        select
            id,
            role_name
        from
            roles
        order by
            id
    </select>

</mapper>