<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.korit.ch05api.mapper.UserMapper">
    <resultMap id="UserResultMap" type="User">
        <id property="id" column="user_id"/>
        <result property="email" column="email" />
        <result property="name" column="name" />
        <result property="provider" column="provider" />
        <result property="providerId" column="provider_id" />
        <result property="roleId" column="user_role_id" />
        <association property="role" resultMap="RoleResultMap" />
    </resultMap>

    <resultMap id="RoleResultMap" type="Role">
        <id property="id" column="role_id" />
        <result property="roleName" column="role_name" />
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into users values
        (default, #{email}, #{name}, #{provider}, #{providerId}, #{roleId})
    </insert>

    <select id="selectByProvider" resultMap="UserResultMap">
        select
            u.id as user_id,
            u.email,
            u.name,
            u.provider,
            u.provider_id,

            u.role_id as user_role_id,
            r.id as role_id,
            r.role_name
        from
            users u
            left join roles r on r.id = u.role_id
        where
            u.provider_id = #{providerId}
        order by
            u.id
    </select>

    <select id="selectById" resultMap="UserResultMap">
        select
            u.id as user_id,
            u.email,
            u.name,
            u.provider,
            u.provider_id,
            u.role_id as user_role_id,
            r.id as role_id,
            r.role_name

            r.id as role_id,
            r.role_name
        from
            users u
            left join roles r on r.id = u.role_id
        where
            u.id = #{userId}
        order by
            u.id
    </select>

</mapper>